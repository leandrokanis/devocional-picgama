{
  "openapi": "3.0.0",
  "info": {
    "title": "Devocional WhatsApp Bot API",
    "description": "API para envio automatizado de devocionais via WhatsApp e gerenciamento operacional.",
    "version": "2.0.0"
  },
  "servers": [
    {
      "url": "http://localhost:4000",
      "description": "Local server"
    }
  ],
  "paths": {
    "/": {
      "get": {
        "tags": ["System"],
        "summary": "API root",
        "responses": {
          "200": {
            "description": "API metadata",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RootResponse"
                }
              }
            }
          }
        }
      }
    },
    "/health": {
      "get": {
        "tags": ["System"],
        "summary": "Health check",
        "responses": {
          "200": {
            "description": "Service health",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api-docs": {
      "get": {
        "tags": ["System"],
        "summary": "OpenAPI specification",
        "responses": {
          "200": {
            "description": "OpenAPI JSON"
          }
        }
      }
    },
    "/send": {
      "post": {
        "tags": ["Devotional"],
        "summary": "Send today's devotional",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Send succeeded",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SendResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Send failed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/readings/today": {
      "get": {
        "tags": ["Devotional"],
        "summary": "Get today's reading",
        "responses": {
          "200": {
            "description": "Today's reading",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DevotionalReading"
                }
              }
            }
          },
          "404": {
            "description": "Reading not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/readings": {
      "get": {
        "tags": ["Devotional"],
        "summary": "List readings",
        "parameters": [
          {
            "name": "date",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "format": "date"
            },
            "description": "Filter by date (YYYY-MM-DD)"
          }
        ],
        "responses": {
          "200": {
            "description": "Readings list",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ReadingsResponse"
                }
              }
            }
          }
        }
      }
    },
    "/qr": {
      "get": {
        "tags": ["WhatsApp"],
        "summary": "Get WhatsApp QR status",
        "description": "Returns QR data URL when WhatsApp is disconnected. Optional reconnect can force a fresh auth cycle.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "reconnect",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean"
            },
            "description": "Force WhatsApp reconnection"
          }
        ],
        "responses": {
          "200": {
            "description": "QR status",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/QrResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/scheduler/status": {
      "get": {
        "tags": ["Scheduler"],
        "summary": "Get scheduler status",
        "responses": {
          "200": {
            "description": "Scheduler status",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SchedulerStatus"
                }
              }
            }
          }
        }
      }
    },
    "/scheduler/start": {
      "post": {
        "tags": ["Scheduler"],
        "summary": "Start scheduler",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Scheduler started",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SendResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/scheduler/stop": {
      "post": {
        "tags": ["Scheduler"],
        "summary": "Stop scheduler",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Scheduler stopped",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SendResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/recipients": {
      "get": {
        "tags": ["Recipients"],
        "summary": "List recipients",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Recipients list",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Recipient"
                      }
                    }
                  },
                  "required": ["data"]
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["Recipients"],
        "summary": "Create recipient",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RecipientRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Recipient created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Recipient"
                }
              }
            }
          },
          "400": {
            "description": "Invalid payload",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "409": {
            "description": "Conflict",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/recipients/{id}": {
      "get": {
        "tags": ["Recipients"],
        "summary": "Get recipient by ID",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Recipient",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Recipient"
                }
              }
            }
          },
          "404": {
            "description": "Not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "put": {
        "tags": ["Recipients"],
        "summary": "Update recipient",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RecipientRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Recipient updated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Recipient"
                }
              }
            }
          },
          "400": {
            "description": "Invalid payload",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "delete": {
        "tags": ["Recipients"],
        "summary": "Delete recipient",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Recipient deleted",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean"
                    }
                  },
                  "required": ["success"]
                }
              }
            }
          },
          "404": {
            "description": "Not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "Token"
      }
    },
    "schemas": {
      "RootResponse": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "version": { "type": "string" },
          "docs": { "type": "string" },
          "health": { "type": "string" }
        },
        "required": ["name", "version", "docs", "health"]
      },
      "SendResponse": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean" },
          "message": { "type": "string" }
        },
        "required": ["success"]
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean", "example": false },
          "error": { "type": "string" }
        },
        "required": ["error"]
      },
      "HealthResponse": {
        "type": "object",
        "properties": {
          "status": { "type": "string" },
          "connected": { "type": "boolean" },
          "hasQRCode": { "type": "boolean" },
          "scheduler": { "$ref": "#/components/schemas/SchedulerStatus" }
        },
        "required": ["status", "connected", "hasQRCode", "scheduler"]
      },
      "QrResponse": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean" },
          "connected": { "type": "boolean" },
          "qr": {
            "type": ["string", "null"],
            "description": "QR code as data URL (data:image/png;base64,...)"
          },
          "message": { "type": "string" }
        },
        "required": ["success", "connected", "qr", "message"]
      },
      "SchedulerStatus": {
        "type": "object",
        "properties": {
          "running": { "type": "boolean" },
          "nextExecution": { "type": "string" },
          "sendTime": { "type": "string" },
          "timezone": { "type": "string" }
        },
        "required": ["running"]
      },
      "Recipient": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "chatId": { "type": "string" },
          "name": { "type": "string" },
          "type": { "type": "string", "enum": ["group", "person"] },
          "createdAt": { "type": "string", "format": "date-time" },
          "updatedAt": { "type": "string", "format": "date-time" }
        },
        "required": ["id", "chatId", "name", "type", "createdAt", "updatedAt"]
      },
      "RecipientRequest": {
        "type": "object",
        "properties": {
          "chat_id": { "type": "string" },
          "name": { "type": "string" },
          "type": { "type": "string", "enum": ["group", "person"] }
        },
        "required": ["chat_id", "name", "type"]
      },
      "DevotionalReading": {
        "type": "object",
        "properties": {
          "date": { "type": "string", "format": "date" },
          "reading": { "type": "string" }
        },
        "required": ["date", "reading"]
      },
      "ReadingsResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/DevotionalReading"
            }
          },
          "metadata": {
            "type": "object",
            "properties": {
              "count": { "type": "integer" },
              "filteredBy": { "type": "string", "format": "date" }
            },
            "required": ["count"]
          }
        },
        "required": ["data", "metadata"]
      }
    }
  },
  "tags": [
    { "name": "System" },
    { "name": "Devotional" },
    { "name": "WhatsApp" },
    { "name": "Scheduler" },
    { "name": "Recipients" }
  ]
}
