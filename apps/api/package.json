{
  "name": "@devocional/api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.build.json && (cp src/swagger.json dist/swagger.json 2>/dev/null || true) && (cp -r data dist/ 2>/dev/null || true) && prisma generate",
    "start": "node dist/index.js",
    "test": "vitest run ./src",
    "lint": "tsc -p tsconfig.json --noEmit",
    "send": "tsx src/index.ts send",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "dotenv -e ../../.env -- prisma migrate dev",
    "prisma:deploy": "dotenv -e ../../.env -- prisma migrate deploy"
  },
  "dependencies": {
    "@prisma/client": "6",
    "@types/qrcode": "^1.5.6",
    "@whiskeysockets/baileys": "^7.0.0-rc.9",
    "dotenv": "^17.2.3",
    "node-cron": "^4.2.1",
    "pino": "^10.1.0",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "dotenv-cli": "^8.0.0",
    "@types/node": "^25.0.3",
    "@types/node-cron": "^3.0.11",
    "prisma": "6",
    "tsx": "^4.19.0",
    "typescript": "^5.9.2",
    "vitest": "^2.1.0"
  }
}
