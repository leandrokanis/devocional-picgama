{
  "name": "devocional-picgama",
  "private": true,
  "version": "2.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "dev:api": "turbo run dev --filter=@devocional/api",
    "dev:ui": "turbo run dev --filter=@devocional/ui",
    "build:api": "turbo run build --filter=@devocional/api",
    "build:ui": "turbo run build --filter=@devocional/ui"
  },
  "devDependencies": {
    "turbo": "^2.5.6",
    "typescript": "^5.9.2"
  },
  "packageManager": "yarn@1.22.22"
}
