{
  "name": "devocional-picgama",
  "version": "1.0.0",
  "description": "Bot automatizado para envio diário de textos bíblicos devocionais via WhatsApp",
  "main": "dist/index.js",
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "yarn install --frozen-lockfile && tsc -p tsconfig.build.json && cp src/swagger.json dist/swagger.json 2>/dev/null || true && cp -r data dist/ 2>/dev/null || true",
    "start": "node dist/index.js",
    "test": "vitest run ./src",
    "send": "tsx src/index.ts send",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "docker:build": "docker compose build",
    "docker:restart": "docker compose restart",
    "postinstall": "echo 'Dependencies installed successfully'"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.0.3",
    "@types/node-cron": "^3.0.11",
    "tsx": "^4.19.0",
    "typescript": "^5.9.2",
    "vitest": "^2.1.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@types/qrcode": "^1.5.6",
    "@whiskeysockets/baileys": "^7.0.0-rc.9",
    "better-sqlite3": "^12.6.2",
    "dotenv": "^17.2.3",
    "node-cron": "^4.2.1",
    "pino": "^10.1.0",
    "qrcode": "^1.5.4"
  }
}
